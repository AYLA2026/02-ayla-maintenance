# ============================================
# Ayla Maintenance - Environment Variables
# ============================================

# Next.js
NEXT_PUBLIC_APP_NAME=Ayla Maintenance
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-this-in-production

# ============================================
# Supabase (قاعدة البيانات)
# ============================================
# احصل على هذه القيم من: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ============================================
# PostgreSQL (محلي - اختياري)
# ============================================
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ayla_db

# ============================================
# Twilio WhatsApp
# ============================================
# احصل على هذه القيم من: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886

# ============================================
# Cloudinary (رفع الصور)
# ============================================
# احصل على هذه القيم من: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# AI Analysis (OpenAI - اختياري)
# ============================================
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
