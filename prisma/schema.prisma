generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model app_settings {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key        String    @unique @db.VarChar(100)
  value      Json?
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model cleaning_reports {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id  String?   @db.Uuid
  school_id   String?   @db.Uuid
  date        DateTime? @db.Date
  inspector   String?   @db.Uuid
  areas       Json?     @default("[]")
  total_score Decimal?  @default(0) @db.Decimal(4, 2)
  status      String?   @default("pass") @db.VarChar(50)
  images      Json?     @default("[]")
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  employee employees? @relation(fields: [inspector], references: [id], onUpdate: NoAction)
  project  projects?  @relation(fields: [project_id], references: [id], onUpdate: NoAction)
  school   schools?   @relation(fields: [school_id], references: [id], onUpdate: NoAction)
}

model complaints {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id    String?   @db.Uuid
  school_id     String?   @db.Uuid
  category      String?   @db.VarChar(50)
  sub_category  String?   @db.VarChar(255)
  description   String?
  priority      String?   @default("medium") @db.VarChar(20)
  status        String?   @default("pending") @db.VarChar(50)
  source        String?   @default("direct") @db.VarChar(50)
  reported_by   String?   @db.VarChar(255)
  assigned_to   String?   @db.Uuid
  ai_analysis   String?
  ai_confidence Decimal?  @db.Decimal(5, 2)
  images_before Json?     @default("[]")
  images_after  Json?     @default("[]")
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  completed_at  DateTime? @db.Timestamptz(6)

  employee employees? @relation(fields: [assigned_to], references: [id], onUpdate: NoAction)
  project  projects?  @relation(fields: [project_id], references: [id], onUpdate: NoAction)
  school   schools?   @relation(fields: [school_id], references: [id], onUpdate: NoAction)
  messages whatsapp_messages[]

  @@index([school_id], map: "idx_complaints_school")
  @@index([status], map: "idx_complaints_status")
}

model employee_whatsapp {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id     String? @db.Uuid
  whatsapp_number String  @db.VarChar(20)
  is_primary      Boolean @default(false)
}

model employees {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @db.VarChar(255)
  cleaning_reports cleaning_reports[]
  complaints       complaints[]
}

model projects {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @db.VarChar(255)
  cleaning_reports cleaning_reports[]
  complaints       complaints[]
}

model schools {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @db.VarChar(255)
  cleaning_reports cleaning_reports[]
  complaints       complaints[]
}

model whatsapp_messages {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complaint_id String?     @db.Uuid
  message_body String?
  created_at   DateTime?   @default(now()) @db.Timestamptz(6)
  complaint    complaints? @relation(fields: [complaint_id], references: [id])
}
// === جداول نظام البلاغات ===

model School {
  id          String   @id @default(cuid())
  name        String
  referenceNo String   @unique
  address     String?
  building    String?
  phone       String?
  whatsappNo  String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supervisors SchoolSupervisor[]
  reports     Report[]
}

model Supervisor {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  email       String?
  whatsappNo  String   @unique
  password    String
  role        SupervisorRole @default(SUPERVISOR)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schools   SchoolSupervisor[]
  reports   Report[] @relation("SupervisorReports")
}

model SchoolSupervisor {
  id           String @id @default(cuid())
  schoolId     String
  supervisorId String
  
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  
  assignedAt   DateTime @default(now())
  
  @@unique([schoolId, supervisorId])
}

model Technician {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  whatsappNo  String   @unique
  email       String?
  password    String
  specialty   String?
  isActive    Boolean  @default(true)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reports     Report[] @relation("TechnicianReports")
}

model Report {
  id              String      @id @default(cuid())
  reportNo        String      @unique @default(cuid())
  title           String
  description     String
  category        ReportCategory
  priority        Priority    @default(MEDIUM)
  status          ReportStatus @default(PENDING)
  
  senderPhone     String
  senderName      String?
  senderType      SenderType  @default(UNKNOWN)
  
  schoolId        String?
  school          School?     @relation(fields: [schoolId], references: [id])
  
  supervisorId    String?
  supervisor      Supervisor? @relation("SupervisorReports", fields: [supervisorId], references: [id])
  
  technicianId    String?
  technician      Technician? @relation("TechnicianReports", fields: [technicianId], references: [id])
  
  images          Json?
  location        Json?
  messages        Message[]
  
  rating          Int?
  feedback        String?
  
  receivedAt      DateTime    @default(now())
  assignedAt      DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  closedAt        DateTime?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([status])
  @@index([schoolId])
  @@index([senderPhone])
  @@index([receivedAt])
}

model Message {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  from      String
  to        String
  content   String
  type      MessageType @default(TEXT)
  mediaUrl  String?
  
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum ReportCategory {
  ELECTRICAL
  PLUMBING
  HVAC
  CARPENTRY
  PAINTING
  CLEANING
  SECURITY
  IT
  FURNITURE
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReportStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CLOSED
  CANCELLED
}

enum SenderType {
  WHATSAPP_SCHOOL
  WHATSAPP_DIRECT
  PLATFORM_API
  MANUAL
  UNKNOWN
}

enum MessageType {
  TEXT
  IMAGE
  LOCATION
  AUDIO
  DOCUMENT
}

enum SupervisorRole {
  ADMIN
  SUPERVISOR
  MANAGER
}